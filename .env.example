# ── Application ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3001

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=creature_world
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creature_world

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication (CHANGE IN PRODUCTION!) ────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-this-refresh-secret-to-long-random-string
JWT_REFRESH_EXPIRES_IN=30d

# ── Encryption for API keys (MUST be 32 characters) ──────
ENCRYPTION_KEY=change-this-32-char-aes-key-prod!

# ── Game Config ───────────────────────────────────────────
PROMPT_COOLDOWN_HOURS=4
MAX_PROMPT_LENGTH=2000
MAX_ACTIONS_PER_PLAN=20
SIMULATION_TICK_HZ=10
MAX_ACTIVE_CREATURES=5000
CHUNK_SIZE=64
TILE_SIZE=32
THROTTLE_LIMIT=60
